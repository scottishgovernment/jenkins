#!/bin/sh -eu

host="${env}${host}.${env}.${domain}"
progname=/opt/checker/checker

set -- /opt/checker/checker
if [ "$stop" = true ]; then
  set -- "$@" "--stop"
fi
set -- "$@" "$type"

cat <<EOF
Running \`$*\` on ${host}
Follow \`syslog_program:checker\` in Kibana for logs.

EOF
set -x

ssh "devops@${host}" \
  sudo systemd-run \
    --unit=checker \
    --collect \
    "$@"
